---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allDecisions = await getCollection('decisions');
  return allDecisions
    .filter(d => d.id.startsWith('en/'))
    .map((decision) => ({
      params: { slug: decision.id.replace('en/', '') },
    }));
}

return Astro.redirect(`/ko/decisions/${Astro.params.slug}`, 301);
---
