---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('writing', ({ data }) => data.draft === false);
  return allArticles
    .filter(a => a.id.startsWith('en/'))
    .map((article) => ({
      params: { slug: article.id.replace('en/', '') },
    }));
}

return Astro.redirect(`/ko/writing/${Astro.params.slug}`, 301);
---
