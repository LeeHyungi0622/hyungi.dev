---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import StructuredData from '../../components/StructuredData.astro';
import ForwardLink from '../../components/ForwardLink.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config';
import type { Lang } from '../../i18n';
import { useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'ko' } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.id.startsWith(`${lang}/`) && p.data.featured === true)
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 6);

const allDecisions = await getCollection('decisions');
const recentDecisions = allDecisions
  .filter(d => d.id.startsWith(`${lang}/`))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

function getSlug(id: string) {
  return id.replace(`${lang}/`, '');
}
---

<BaseLayout lang={lang}>
  <SEO
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <StructuredData type="WebSite" />
  <StructuredData type="Person" />

  <main class="home-page">
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-left">
          <div class="hero-sub">
            {t('hero.tagline')}<br/><br/>
            <span class="hero-sub">{t('hero.sub1')}</span><br/><br/>
            <span class="hero-sub">{t('hero.sub2')}</span><br/><br/>
          </div>
          <p class="hero-meta">
            {t('hero.intro1').replace('{name}', siteConfig.author.name).replace('{title}', siteConfig.author.title)}
          </p>
          <div class="hero-intro">
            <p>{t('hero.intro2')}</p>
            <ForwardLink href={`/${lang}/journey`} text={t('hero.journey')} variant="muted" />
          </div>
        </div>

        <div class="hero-right">
          <div class="section-header">
            <h2>{t('hero.section')}</h2>
            <ForwardLink href={`/${lang}/projects`} text={t('section.viewAll')} variant="muted" />
          </div>
          <div class="case-snapshots">
            {featuredProjects.map((project) => (
              <a href={`/${lang}/projects/${getSlug(project.id)}`} class="case-snapshot">
                <span class="case-label">Case · {project.data.role}</span>
                <span class="case-title">{project.data.title}</span>
                <span class="case-outcome">{project.data.outcomeSummary}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="two-col-sections">
      <section class="recent-decisions">
        <div class="section-header">
          <h2>{t('section.recentDecisions')}</h2>
          <ForwardLink href={`/${lang}/decisions`} text={t('section.viewAll')} variant="muted" />
        </div>

        {recentDecisions.length > 0 ? (
          <div class="decisions-list">
            {recentDecisions.map((decision) => {
              const date = new Date(decision.data.date);
              const formattedDate = date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
              return (
                <article class="decision-item">
                  <span class="decision-date">{formattedDate}</span>
                  <h3 class="decision-title">{decision.data.title}</h3>
                  <p class="decision-context">{decision.data.context}</p>
                </article>
              );
            })}
          </div>
        ) : (
          <p class="no-decisions">{t('decisions.empty')}</p>
        )}
      </section>

      <section class="thinking">
        <h2>{t('section.problems')}</h2>
        <p class="thinking-list">{t('section.problemsList')}</p>
      </section>
    </div>
  </main>

  <style>
    .home-page {
      max-width: 1700px;
      margin: 0 auto;
      padding: 0 1.5rem 2rem;
    }

    .hero {
      padding: 2rem 0 2rem;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 2rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: space-around;
      height: 100%;
      padding-right: 2rem;
    }

    .hero-sub {
      font-size: 1.125rem;
      color: var(--color-text-secondary);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .hero-sub-em {
      font-size: 1.25rem;
      font-weight: 900;
      color: var(--color-text)
    }

    .hero-meta {
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
      letter-spacing: 0.01em;
    }

    .hero-right {
      padding-top: 0.5rem;
    }

    .case-snapshots {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .case-snapshot {
      display: block;
      padding: 1.25rem 1.5rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      text-decoration: none;
      transition: border-color 0.2s ease, background 0.2s ease;
    }

    .case-snapshot:hover {
      border-color: var(--color-text-muted);
      background: var(--color-bg-elevated);
    }

    .case-label {
      display: block;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-muted);
      margin-bottom: 0.375rem;
    }

    .case-title {
      display: block;
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: 0.5rem;
      line-height: 1.4;
    }

    .case-outcome {
      display: block;
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      line-height: 1.5;
    }

    .hero-intro {
      margin-top: 1.5rem;
      font-size: 1.125rem;
      line-height: 1.7;
      color: var(--color-text-secondary);
    }

    .hero-intro p {
      margin-bottom: 1rem;
    }

    .hero-intro p:first-child {
      color: var(--color-text);
    }

    .two-col-sections {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .decisions-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid var(--color-border);
    }

    .decision-item {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .decision-item:last-child {
      border-bottom: none;
    }

    .decision-date {
      display: block;
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .decision-title {
      font-size: 1.125rem;
      font-weight: 600;
      line-height: 1.3;
      color: var(--color-text);
      margin-bottom: 0.5rem;
    }

    .decision-context {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--color-text-secondary);
    }

    .no-decisions {
      color: var(--color-text-muted);
      font-style: italic;
      padding: 1.5rem 0;
    }

    .thinking {
      margin-bottom: 5rem;
    }

    .thinking h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
      letter-spacing: -0.01em;
    }

    .thinking-list {
      font-size: 1.0625rem;
      line-height: 1.9;
      color: var(--color-text-secondary);
    }

    @media (max-width: 768px) {
      .home-page { padding: 0 1rem 3rem; }
      .hero { padding: 2.5rem 0 3rem; }
      .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .hero-left { padding-right: 0; }
      .case-snapshots { grid-template-columns: 1fr; }
      .hero-intro { font-size: 1rem; }
      .two-col-sections { grid-template-columns: 1fr; gap: 3rem; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .decision-title { font-size: 1rem; }
    }
  </style>
</BaseLayout>
